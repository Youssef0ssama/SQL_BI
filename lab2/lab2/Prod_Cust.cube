  <MdxScripts>
    <MdxScript dwd:design-time-name="769feb95-66a3-4669-986d-6340250607f7">
      <ID>MdxScript</ID>
      <Name>MdxScript</Name>
      <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
      <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
      <Commands>
        <Command>
          <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE; 
CREATE MEMBER CURRENTCUBE.[Measures].[Sales Unite Price]
 AS [Measures].[Qty Total price] / [Measures].[Qty], 
VISIBLE = 1  ; </Text>
        </Command>
      </Commands>
      <CalculationProperties>
        <CalculationProperty dwd:design-time-name="ca4f2703-ee87-4edb-8827-ce8c0070ee18">
          <CalculationReference>[Measures].[Sales Unite Price]</CalculationReference>
          <CalculationType>Member</CalculationType>
          <Translations>
            <Translation dwd:design-time-name="9b8d7cf3-0e55-4cc8-8b03-e3286b5badef">
              <Language>3073</Language>
              <Caption>سعر الوحدة</Caption>
            </Translation>
          </Translations>
        </CalculationProperty>
      </CalculationProperties>
    </MdxScript>
  </MdxScripts>
  <Kpis>
    <Kpi dwd:design-time-name="4e0b343e-dcea-48c9-a797-d199de1e3ce0">
      <ID>KPI</ID>
      <Name>Qty KPI</Name>
      <Translations>
        <Translation dwd:design-time-name="afaa26f4-f5cc-49d3-9d54-8206d24c0ad8">
          <Language>3073</Language>
          <Caption>مؤشر الكمية</Caption>
        </Translation>
      </Translations>
      <Value>[Measures].[Qty]</Value>
      <Goal>1000</Goal>
      <Status>IIF([Measures].[Qty] &gt;= 1000, 1, -1)</Status>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Smiley Face</StatusGraphic>
    </Kpi>
